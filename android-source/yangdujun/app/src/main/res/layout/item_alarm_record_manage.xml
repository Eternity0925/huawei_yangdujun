<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:clipChildren="false" android:clipToPadding="false">
    <View android:layout_width="120dp" android:layout_height="120dp" android:layout_gravity="top|end" android:layout_marginTop="-30dp" android:layout_marginEnd="-20dp" android:alpha="0.2" android:background="@drawable/abc_control_background_material" android:backgroundTint="#A8C69F" />
    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="12dp" android:layout_marginVertical="8dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="20dp" app:cardElevation="4dp">
        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
            <TextView android:id="@+id/tv_greenhouse" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="大棚1" android:textSize="@dimen/text_size_14" android:textColor="#2E7D32" android:textStyle="bold" android:ellipsize="end" android:singleLine="true" android:layout_marginEnd="8dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
            <TextView android:id="@+id/tv_device" android:layout_width="0dp" android:layout_height="wrap_content" android:text="温度传感器" android:textSize="@dimen/text_size_14" android:textColor="#9EBA95" android:ellipsize="end" android:singleLine="true" android:layout_marginStart="6dp" app:layout_constraintEnd_toStartOf="@id/tv_status" app:layout_constraintStart_toEndOf="@id/tv_greenhouse" app:layout_constraintTop_toTopOf="@id/tv_greenhouse" app:layout_constraintHorizontal_bias="0.0" />
            <TextView android:id="@+id/tv_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="未处理" android:textSize="@dimen/text_size_12" android:textColor="#FFFFFF" android:ellipsize="end" android:singleLine="true" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:background="#EA4B4B" android:gravity="center" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/tv_greenhouse" />
            <TextView android:id="@+id/tv_alarm_content" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="温度过高，当前值：35°C" android:textSize="@dimen/text_size_14" android:textColor="#EF5757" android:textStyle="bold" android:ellipsize="end" android:singleLine="false" android:maxLines="2" android:layout_marginTop="12dp" app:layout_constraintTop_toBottomOf="@id/tv_greenhouse" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
            <TextView android:id="@+id/tv_alarm_time" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="2024-01-01 12:00:00" android:textSize="@dimen/text_size_12" android:textColor="#9EBA95" android:ellipsize="end" android:singleLine="true" android:layout_marginTop="8dp" android:gravity="end" app:layout_constraintTop_toBottomOf="@id/tv_alarm_content" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
    <View android:layout_width="30dp" android:layout_height="30dp" android:layout_gravity="bottom|start" android:layout_marginStart="5dp" android:layout_marginBottom="2dp" android:alpha="0.5" android:background="@drawable/abc_control_background_material" android:backgroundTint="#A8C69F" android:elevation="50dp" />
</FrameLayout>