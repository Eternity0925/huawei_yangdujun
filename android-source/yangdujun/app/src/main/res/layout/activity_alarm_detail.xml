<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E9F2E6"
    tools:context=".AlarmDetailActivity">

    <View
        android:id="@+id/bg_circle_bottom_1"
        android:layout_width="268dp"
        android:layout_height="268dp"
        android:layout_marginStart="-60dp"
        android:layout_marginTop="-80dp"
        android:alpha="0.2"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bg_circle_bottom_2"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:alpha="0.08"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="100dp"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_margin="16dp"
        android:elevation="12dp"
        app:cardBackgroundColor="#A8C69F"
        app:cardCornerRadius="28dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="74dp"
                android:layout_height="38dp"
                android:layout_marginStart="16dp"
                android:background="@android:drawable/btn_default_small"
                android:backgroundTint="#99BF92"
                android:elevation="2dp"
                android:stateListAnimator="@null"
                android:text="返回"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="告警处理详情"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@android:drawable/presence_online"
                    android:backgroundTint="#A8C69F">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="✓"
                        android:textColor="#FFFFFF"
                        android:textSize="44sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="任务已处理完成"
                    android:textColor="#5A7D54"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:elevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="工单编号" android:textColor="#9EBA95" />
                        <TextView android:id="@+id/tv_order_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:text="20201207094601" android:textColor="#4A6142" android:textStyle="bold" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F5EF" android:layout_marginBottom="12dp"/>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="告警位置" android:textColor="#9EBA95" />
                        <TextView android:id="@+id/tv_alarm_pos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:text="1#大棚温度传感器" android:textColor="#4A6142" android:textStyle="bold" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F5EF" android:layout_marginBottom="12dp"/>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="告警时间" android:textColor="#9EBA95" />
                        <TextView android:id="@+id/tv_alarm_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:text="2020-12-07 12:56:01" android:textColor="#4A6142" android:textStyle="bold" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F5EF" android:layout_marginBottom="12dp"/>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="责任人" android:textColor="#9EBA95" />
                        <TextView android:id="@+id/tv_handler" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:text="王昊洋" android:textColor="#A8C69F" android:textStyle="bold" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F5EF" android:layout_marginBottom="12dp"/>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="联系电话" android:textColor="#9EBA95" />
                        <TextView android:id="@+id/tv_phone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:text="暂无" android:textColor="#4A6142" android:textStyle="bold" />
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!-- 内容 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:elevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="内容"
                    android:textSize="18sp"
                    android:textColor="#1B320E"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/tv_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1#大棚温度传感器温度过高告警"
                    android:textSize="16sp"
                    android:textColor="#666666"/>
            </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_timeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:elevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="20dp" android:text="处理进度" android:textColor="#4A6142" android:textSize="17sp" android:textStyle="bold" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:layout_marginTop="4dp" android:background="@android:drawable/presence_online" android:backgroundTint="#A8C69F" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="发布告警" android:textColor="#4A6142" android:textStyle="bold" />
                            <TextView android:id="@+id/tv_publish_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#4A6142" android:text="2020/12/07 12:56" android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                    <View android:layout_width="2dp" android:layout_height="30dp" android:layout_marginStart="5dp" android:background="#E9F2E6" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:layout_marginTop="4dp" android:background="@android:drawable/presence_online" android:backgroundTint="#A8C69F" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="处理完成" android:textColor="#4A6142" android:textStyle="bold" />
                            <TextView android:id="@+id/tv_complete_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2020/12/07 16:48" android:textSize="12sp" android:textColor="#4A6142" />
                            <TextView android:id="@+id/tv_operate" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="#F8FCF7" android:padding="10dp" android:text="已经通过APP手动开启1#大棚风机,运行1小时" android:textColor="#7A9A71" android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/bg_circle_top_漂流1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:alpha="0.15"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        android:elevation="100dp"
        app:layout_constraintEnd_toEndOf="@id/topBar"
        app:layout_constraintTop_toTopOf="@id/topBar"
        android:layout_marginEnd="30dp"
        android:layout_marginTop="20dp"/>

    <View
        android:id="@+id/bg_circle_top_漂流2"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:alpha="0.1"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        android:elevation="100dp"
        app:layout_constraintBottom_toBottomOf="@id/contentScroll"
        app:layout_constraintStart_toStartOf="@id/contentScroll"
        android:layout_marginStart="50dp"
        android:layout_marginBottom="180dp"/>

    <View
        android:id="@+id/bg_circle_top_漂流3"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:alpha="0.08"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        android:elevation="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="80dp"
        android:layout_marginBottom="40dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>