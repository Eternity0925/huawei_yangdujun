<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E9F2E6"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginStart="-120dp"
        android:layout_marginTop="-80dp"
        android:alpha="0.15"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginEnd="-60dp"
        android:layout_marginBottom="200dp"
        android:alpha="0.08"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="1dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#A8C69F"
            app:cardCornerRadius="30dp"
            app:cardElevation="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/iv_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="16dp"
                    android:background="@android:drawable/btn_default_small"
                    android:backgroundTint="#87AF7C"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="羊肚菌AI小助手"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● 你提问的内容"
                    android:textColor="#9EBA95"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/textSpeechTO"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待输入..."
                    android:textColor="#4A6142"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#F2F6F1"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● AI 专家回答"
                    android:textColor="#7A9A71"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/textSpeechFrom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="你好！我是您的种植助手。"
                    android:textColor="#3A5E3E"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:scrollbars="none">

                <TextView
                    android:id="@+id/tv_history_record"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    android:text="历史记录加载中..."
                    android:textColor="#5A7D54"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"/>
            </ScrollView>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp">

            <EditText
                android:id="@+id/et_text_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="向助手提问种植问题..."
                android:minHeight="56dp"
                android:paddingHorizontal="20dp"
                android:textColor="#4A6142"
                android:textColorHint="#BDD1B8"
                android:textSize="15sp" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_send_text"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@android:drawable/btn_default"
                android:backgroundTint="#A8C69F"
                android:stateListAnimator="@null"
                android:text="发送文字"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/bt_opencloseSpeech"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@android:drawable/btn_default"
                android:backgroundTint="#6BA878"
                android:stateListAnimator="@null"
                android:text="按住说话"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="140dp"
        android:alpha="0.12"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        android:elevation="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="160dp"
        android:alpha="0.1"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        android:elevation="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginEnd="60dp"
        android:layout_marginBottom="40dp"
        android:alpha="0.08"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#A8C69F"
        android:elevation="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>