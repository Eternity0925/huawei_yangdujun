<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#E9F2E6">
    <View android:layout_width="400dp" android:layout_height="400dp" android:layout_gravity="top|center_horizontal" android:layout_marginTop="-150dp" android:alpha="0.2" android:background="@drawable/abc_control_background_material" android:backgroundTint="#A8C69F" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:background="@drawable/image_9" android:backgroundTint="#CCFFFFFF" android:backgroundTintMode="src_over">
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:paddingHorizontal="@dimen/margin_20">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/margin_20" android:gravity="center" android:text="温芯菌控管理系统" android:textColor="#1B320E" android:textSize="@dimen/text_size_30" android:textStyle="bold" />
            <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="@dimen/margin_20" app:cardCornerRadius="100dp" app:cardElevation="15dp" app:cardBackgroundColor="#00FFFFFF">
                <ImageView android:id="@+id/img14" android:layout_width="180dp" android:layout_height="180dp" android:adjustViewBounds="true" android:scaleType="fitCenter" android:src="@drawable/image_14" />
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="40dp" android:gravity="center" android:text="创新惠农       科技助农" android:textColor="#547A3E" android:textSize="@dimen/text_size_20" android:textStyle="bold" android:letterSpacing="0.1" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical">
                <Button android:id="@+id/btn_login1" android:layout_width="match_parent" android:layout_height="@dimen/btn_height" android:backgroundTint="#2E7D32" android:text="登录" android:textColor="#FFFFFF" android:textSize="@dimen/text_size_18" android:textStyle="bold" app:cornerRadius="25dp" />
                <Button android:id="@+id/reg" android:layout_width="match_parent" android:layout_height="@dimen/btn_height" android:layout_marginTop="@dimen/margin_15" android:backgroundTint="#A8C69F" android:text="注册" android:textColor="#FFFFFF" android:textSize="@dimen/text_size_18" android:textStyle="bold" app:cornerRadius="25dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <View android:layout_width="25dp" android:layout_height="25dp" android:layout_gravity="bottom|end" android:layout_marginEnd="30dp" android:layout_marginBottom="40dp" android:alpha="0.5" android:background="@drawable/abc_control_background_material" android:backgroundTint="#2E7D32" android:elevation="50dp" />
</FrameLayout>
