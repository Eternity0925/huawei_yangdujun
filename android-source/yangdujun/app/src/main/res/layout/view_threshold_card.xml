<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="监测项名称"
            android:textColor="#5A8C62"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="设定下限"
                android:textColor="#9EBA95"
                android:textSize="13sp"/>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_min_sub"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="-"
                android:backgroundTint="#6BA878"
                android:textColor="#FFFFFF"
                android:minHeight="0dp"
                android:minWidth="0dp"
                app:cornerRadius="8dp"/>
            <TextView
                android:id="@+id/tv_min_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:gravity="center"
                android:textColor="#4A6142"
                android:textSize="16sp"
                android:textStyle="bold" />
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_min_add"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="+"
                android:backgroundTint="#6BA878"
                android:textColor="#FFFFFF"
                android:minHeight="0dp"
                android:minWidth="0dp"
                app:cornerRadius="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="设定上限"
                android:textColor="#9EBA95"
                android:textSize="13sp"/>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_max_sub"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="-"
                android:backgroundTint="#6BA878"
                android:textColor="#FFFFFF"
                android:minHeight="0dp"
                android:minWidth="0dp"
                app:cornerRadius="8dp"/>
            <TextView
                android:id="@+id/tv_max_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="100"
                android:gravity="center"
                android:textColor="#4A6142"
                android:textSize="16sp"
                android:textStyle="bold" />
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_max_add"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="+"
                android:backgroundTint="#6BA878"
                android:textColor="#FFFFFF"
                android:minHeight="0dp"
                android:minWidth="0dp"
                app:cornerRadius="8dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>