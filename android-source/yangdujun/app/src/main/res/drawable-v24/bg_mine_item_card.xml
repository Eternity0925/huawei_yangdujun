<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 白色背景 -->
    <solid android:color="#FFFFFF"/>

    <!-- 圆角 -->
    <corners android:radius="6dp"/>

    <!-- 轻边框 -->
    <stroke
        android:width="1dp"
        android:color="#E6E6E6"/>

    <!-- 内边距（可选） -->
    <padding
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp"/>

</shape>

